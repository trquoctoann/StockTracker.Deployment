# ── Compose Project ──────────────────────────────────────────
COMPOSE_PROJECT_NAME=stocktracker

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=stocktracker

# Keycloak database (created by init script)
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=password

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=password

# ── Keycloak ─────────────────────────────────────────────────
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=password
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://postgres:5432/keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=password
KC_HOSTNAME_STRICT=false
KC_HTTP_ENABLED=true
KC_HEALTH_ENABLED=true

# ── StockTracker API ─────────────────────────────────────────
# Application
API_APP_NAME=StockTracker.API
API_APP_VERSION=0.0.1
API_DEBUG=true

# Logging
API_ENVIRONMENT=development
API_SERVICE_NAME=API
API_LOG_LEVEL=INFO
API_LOG_JSON=true
API_LOG_SQL=false

# Database
API_DATABASE_URL=postgresql+asyncpg://postgres:password@postgres:5432/stocktracker
API_DATABASE_POOL_PRE_PING=true
API_DATABASE_POOL_SIZE=5
API_DATABASE_MAX_OVERFLOW=10

# CORS
API_ALLOWED_ORIGINS=["http://localhost:3000"]

# Pagination
API_DEFAULT_PAGE_SIZE=10
API_MAX_PAGE_SIZE=100

# i18n
API_DEFAULT_LOCALE=en
API_SUPPORTED_LOCALES=["en","vi"]

# OIDC Keycloak
API_OIDC_KEYCLOAK_SERVER_URL=http://keycloak:8080/
API_OIDC_KEYCLOAK_REALM=stocktracker
API_OIDC_KEYCLOAK_CLIENT_ID=stocktracker.api
API_OIDC_KEYCLOAK_CLIENT_SECRET=secret
API_OIDC_KEYCLOAK_ADMIN_USERNAME=admin
API_OIDC_KEYCLOAK_ADMIN_PASSWORD=password
API_OIDC_KEYCLOAK_VERIFY_TLS=false

# Context token
API_AUTH_CONTEXT_TOKEN_SECRET=secret
API_AUTH_CONTEXT_TOKEN_ALGORITHM=HS256
API_AUTH_CONTEXT_TOKEN_TTL_SECONDS=300
API_AUTH_CONTEXT_TOKEN_ISSUER=http://localhost:8000/api

# Redis
API_REDIS_ENABLED=true
API_REDIS_URL=redis://:change_me_redis@redis:6379/0
API_REDIS_MAX_CONNECTIONS=10
API_REDIS_SOCKET_CONNECT_TIMEOUT=2
API_REDIS_SOCKET_TIMEOUT=2
API_REDIS_KEY_PREFIX=stocktracker
API_REDIS_KEY_SERVICE_PREFIX=api
API_REDIS_DEFAULT_TTL_SECONDS=300
API_REDIS_CIRCUIT_BREAKER_SECONDS=30

# ── Grafana ──────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=password

# ── Docker Hub ───────────────────────────────────────────────
DOCKER_REGISTRY=docker.io
DOCKER_API_REPO=username/stocktracker-api
DOCKER_USERNAME=username
DOCKER_PASSWORD=password

# ── Jenkins ──────────────────────────────────────────────────
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=password
