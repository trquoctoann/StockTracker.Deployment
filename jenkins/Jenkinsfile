pipeline {
    agent any

    parameters {
        string(
            name: 'BRANCH',
            defaultValue: 'main',
            description: 'Git branch to build'
        )
        choice(
            name: 'ENVIRONMENT',
            choices: ['staging', 'production'],
            description: 'Target deployment environment'
        )
        booleanParam(
            name: 'SKIP_TESTS',
            defaultValue: false,
            description: 'Skip test stage (use cautiously)'
        )
        booleanParam(
            name: 'DEPLOY',
            defaultValue: true,
            description: 'Deploy after successful build'
        )
    }

    environment {
        // Docker Hub credentials (configured in Jenkins Credential Store)
        DOCKER_CREDENTIALS = credentials('dockerhub-credentials')
        DOCKER_API_REPO        = "${env.DOCKER_API_REPO ?: 'stocktracker-api'}"
        DOCKER_REGISTRY    = "${env.DOCKER_REGISTRY ?: 'docker.io'}"

        // Git
        API_REPO_URL = "${env.API_REPO_URL ?: 'https://github.com/your-org/StockTracker.API.git'}"

        // Build metadata
        IMAGE_TAG    = "${params.BRANCH}-${env.BUILD_NUMBER}"
        LATEST_TAG   = "${params.BRANCH == 'main' ? 'latest' : params.BRANCH}"
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timestamps()
    }

    stages {
        // ── Stage 1: Checkout ───────────────────────────────
        stage('Checkout') {
            steps {
                echo "==> Checking out branch: ${params.BRANCH}"
                dir('StockTracker.API') {
                    git branch: params.BRANCH,
                        url: env.API_REPO_URL,
                        credentialsId: 'git-credentials'
                }
                dir('StockTracker.Deployment') {
                    checkout scm
                }
            }
        }

        // ── Stage 2: Lint ───────────────────────────────────
        stage('Lint') {
            when {
                not { expression { params.SKIP_TESTS } }
            }
            steps {
                echo '==> Running linter (ruff)...'
                dir('StockTracker.API') {
                    sh '''
                        pip install --quiet ruff
                        ruff check app/
                        ruff format --check app/
                    '''
                }
            }
        }

        // ── Stage 3: Test ───────────────────────────────────
        stage('Test') {
            when {
                not { expression { params.SKIP_TESTS } }
            }
            steps {
                echo '==> Running tests (pytest)...'
                dir('StockTracker.API') {
                    sh '''
                        pip install --quiet uv
                        uv sync --frozen --dev
                        uv run pytest tests/ \
                            --tb=short \
                            --junitxml=test-results.xml \
                            -q
                    '''
                }
            }
            post {
                always {
                    dir('StockTracker.API') {
                        junit allowEmptyResults: true,
                              testResults: 'test-results.xml'
                    }
                }
            }
        }

        // ── Stage 4: Build Docker Image ─────────────────────
        stage('Build') {
            steps {
                echo "==> Building Docker image: ${DOCKER_API_REPO}:${IMAGE_TAG}"
                dir('StockTracker.API') {
                    sh """
                        docker build \
                            -f ../StockTracker.Deployment/services/api/Dockerfile \
                            -t ${DOCKER_REGISTRY}/${DOCKER_API_REPO}:${IMAGE_TAG} \
                            -t ${DOCKER_REGISTRY}/${DOCKER_API_REPO}:${LATEST_TAG} \
                            --label "git.branch=${params.BRANCH}" \
                            --label "git.commit=\$(git rev-parse --short HEAD)" \
                            --label "build.number=${env.BUILD_NUMBER}" \
                            --label "build.timestamp=\$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
                            .
                    """
                }
            }
        }

        // ── Stage 5: Push to Registry ───────────────────────
        stage('Push') {
            steps {
                echo "==> Pushing to ${DOCKER_REGISTRY}..."
                sh """
                    echo \$DOCKER_CREDENTIALS_PSW | docker login ${DOCKER_REGISTRY} \
                        -u \$DOCKER_CREDENTIALS_USR --password-stdin

                    docker push ${DOCKER_REGISTRY}/${DOCKER_API_REPO}:${IMAGE_TAG}
                    docker push ${DOCKER_REGISTRY}/${DOCKER_API_REPO}:${LATEST_TAG}

                    docker logout ${DOCKER_REGISTRY}
                """
            }
        }

        // ── Stage 6: Deploy ─────────────────────────────────
        stage('Deploy') {
            when {
                expression { params.DEPLOY }
            }
            steps {
                script {
                    if (params.ENVIRONMENT == 'staging') {
                        echo '==> Deploying to staging (Docker Compose)...'
                        dir('StockTracker.Deployment') {
                            sh """
                                export API_APP_VERSION=${IMAGE_TAG}
                                docker compose pull api 2>/dev/null || true
                                docker compose up -d api --force-recreate --no-deps
                            """
                        }
                    } else if (params.ENVIRONMENT == 'production') {
                        echo '==> Deploying to production (Kubernetes)...'
                        // Future K8s deployment:
                        // sh """
                        //     kubectl set image deployment/stocktracker-api \
                        //         api=${DOCKER_REGISTRY}/${DOCKER_API_REPO}:${IMAGE_TAG} \
                        //         -n stocktracker
                        //     kubectl rollout status deployment/stocktracker-api \
                        //         -n stocktracker --timeout=300s
                        // """
                        echo 'K8s deployment not yet configured. Skipping.'
                    }
                }
            }
        }
    }

    post {
        success {
            echo "==> Pipeline SUCCESS: ${DOCKER_API_REPO}:${IMAGE_TAG}"
            // Uncomment to enable Slack notifications:
            // slackSend(
            //     color: 'good',
            //     message: "✅ StockTracker API build #${env.BUILD_NUMBER} succeeded\nBranch: ${params.BRANCH}\nImage: ${DOCKER_API_REPO}:${IMAGE_TAG}"
            // )
        }
        failure {
            echo "==> Pipeline FAILED: ${DOCKER_API_REPO}:${IMAGE_TAG}"
            // slackSend(
            //     color: 'danger',
            //     message: "❌ StockTracker API build #${env.BUILD_NUMBER} failed\nBranch: ${params.BRANCH}"
            // )
        }
        cleanup {
            // Clean up dangling images to save disk space
            sh 'docker image prune -f --filter "until=24h" || true'
        }
    }
}
