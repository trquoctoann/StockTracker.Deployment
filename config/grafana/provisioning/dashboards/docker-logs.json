{
  "annotations": {
    "list": []
  },
  "description": "Docker container logs collected by Grafana Alloy and stored in Loki",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Log Volume by Service",
      "type": "barchart",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "sum by (compose_service) (count_over_time({compose_project=\"stocktracker\", compose_service=~\"$service\"} [$__interval]))",
          "legendFormat": "{{compose_service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Log lines",
            "fillOpacity": 80,
            "gradientMode": "hue",
            "lineWidth": 1,
            "stacking": { "group": "A", "mode": "normal" }
          }
        },
        "overrides": []
      },
      "options": {
        "barRadius": 0.1,
        "groupWidth": 0.7,
        "legend": { "displayMode": "list", "placement": "bottom" },
        "orientation": "auto",
        "tooltip": { "mode": "multi", "sort": "desc" },
        "xTickLabelRotation": 0
      }
    },
    {
      "title": "Live Logs",
      "type": "logs",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "{compose_project=\"stocktracker\", compose_service=~\"$service\"} |= `$search`",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "title": "Errors Only",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "{compose_project=\"stocktracker\", compose_service=~\"$service\"} | json | level =~ `(?i)(error|critical|fatal)`",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["docker", "loki", "stocktracker"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "loki", "uid": "" },
        "definition": "label_values({compose_project=\"stocktracker\"}, compose_service)",
        "includeAll": true,
        "multi": true,
        "name": "service",
        "label": "Service",
        "query": "label_values({compose_project=\"stocktracker\"}, compose_service)",
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "name": "search",
        "label": "Search",
        "type": "textbox",
        "options": []
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Docker Container Logs",
  "uid": "stocktracker-docker-logs",
  "version": 1
}
